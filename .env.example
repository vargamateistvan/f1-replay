# Optional OpenF1 bearer token.
#
# OpenF1's historical data (2023+) is documented as free and requires NO auth.
# If the API starts returning 401/403 for historical requests and you have a
# token (e.g. from a sponsor subscription), copy this file to `.env.local` and
# set the value below — it is sent as `Authorization: Bearer <key>` on every
# request. Leave unset for anonymous access.
VITE_OPENF1_API_KEY=

# Sentry browser SDK DSN (public identifier) used by @sentry/react.
# Copy this file to `.env.local` and set your real value there.
VITE_SENTRY_DSN=

# Optional app release string shown in Sentry events (e.g. git SHA or semver).
VITE_APP_VERSION=
